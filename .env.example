PORT=3000
NODE_ENV=development
# Origen del SPA (Vite). Si Vite usa otro puerto, añádelo separado por coma:
# CLIENT_URL=http://localhost:5173,http://localhost:5174
CLIENT_URL=http://localhost:5173

# Alcance de la API: `full` (todas las rutas) o `spa` (solo lo que usa la app PetConnect)
PETCONNECT_API_SCOPE=full

MONGODB_URI=

JWT_SECRET=
JWT_EXPIRES_IN=7d

MAIL_HOST=
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM="PetConnect <no-reply@petconnect.app>"

# Correos de administradores para avisos. Separar por coma o punto y coma.
ADMIN_NOTIFICATION_EMAILS=admin@ejemplo.com

# Nominatim (OpenStreetMap) — geocodificación de direcciones de proveedores
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_TIMEOUT_MS=7000
NOMINATIM_USER_AGENT="PetConnectBackend/1.0 (contacto: admin@petconnect.app)"

# Usuario admin local (crear o restablecer: npm run seed:admin)
# ADMIN_SEED_EMAIL=admin@petconnect.local
# ADMIN_SEED_PASSWORD=AdminPetConnect2026
# Si "Credenciales inválidas" pero el admin ya existe: en .env pon
# FORCE_ADMIN_PASSWORD=1

# Zona horaria de los bloques de agenda veterinaria (Luxon IANA)
# AGENDA_TIMEZONE=America/Santiago

# --- Chat con OpenAI ---
# Clave NUNCA al frontend. Obtén la tuya en https://platform.openai.com/api-keys
# Modelo recomendado: gpt-4o-mini (económico y rápido). Alternativa nano: gpt-4.1-nano
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHAT_LLM_TIMEOUT_MS=8000

# Contexto por sesión (en memoria). Si necesitas persistencia multi-instancia, migra a Redis.
CHAT_SESSION_TTL_MS=1800000
CHAT_SESSION_MAX_MESSAGES=20
