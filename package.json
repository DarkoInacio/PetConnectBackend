{
  "name": "petconnect-backend",
  "version": "1.0.0",
  "description": "Backend de PetConnect - API REST con Node.js, Express y MongoDB",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
